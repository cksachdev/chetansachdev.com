<nav aria-label="Post pagination">
    <ul class="pager">
        <% if (page.prev){ %>
            <li class="button-previous"><a href="<%- config.root %><%- page.prev_link %>" aria-label="Previous page">← Previous</a></li>
        <% } %>
        <% if (page.next){ %>
            <li class="button-next"><a href="<%- config.root %><%- page.next_link %>" aria-label="Next page">Next →</a></li>
        <% } %>
    </ul>
</nav>