<div class="post-layout">

  <article class="post-article">

    <p class="post-header-meta"><%= item.date.format(config.date_format) %></p>

    <h1 class="post-title"><%- item.title || item.link %></h1>

    <div class="post-body">
      <%- item.content %>
    </div>

    <div class="post-footer">
      <a href="/" class="back-link">Back to all posts</a>
    </div>

    <div class="post-comments">
      <div id="disqus_thread"></div>
      <script>
        var disqus_config = function () {
          this.page.url = '<%- config.url %>/<%- item.path %>';
          this.page.identifier = '<%- item.path %>';
        };
        (function() {
          var d = document, s = d.createElement('script');
          s.src = 'https://chetan-sachdev.disqus.com/embed.js';
          s.setAttribute('data-timestamp', +new Date());
          (d.head || d.body).appendChild(s);
        })();
      </script>
      <noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
    </div>

  </article>

  <%- partial('_partial/sidebar') %>

</div>
