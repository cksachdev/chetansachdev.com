<header class="site-header">
  <div class="header-inner">

    <!-- Brand -->
    <a href="/" class="site-brand">
      <img class="brand-avatar" src="<%- theme.avatar %>" alt="<%= config.author %>">
      <span class="brand-text">
        <span class="brand-name"><%= config.author %></span>
        <span class="brand-tagline"><%= config.subtitle %></span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="site-nav" aria-label="Main navigation">
      <a href="/" class="nav-link">Home</a>
      <a href="/archives/" class="nav-link">Archives</a>
      <a href="https://github.com/cksachdev" class="nav-link" target="_blank" rel="noopener">GitHub</a>
      <a href="/about/" class="nav-link">About</a>
    </nav>

    <!-- Header actions -->
    <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">

      <!-- Search trigger (Cmd+K) -->
      <button class="search-trigger-btn" id="search-trigger" aria-label="Search (⌘K)">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="search-kbd-label">⌘K</span>
      </button>

      <!-- Theme toggle -->
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <!-- Sun icon (shown in dark mode) -->
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

    </div>
  </div>

  <!-- Mobile nav drawer -->
  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
    <a href="/" class="nav-link">Home</a>
    <a href="/archives/" class="nav-link">Archives</a>
    <a href="https://github.com/cksachdev" class="nav-link" target="_blank" rel="noopener">GitHub</a>
    <a href="/about/" class="nav-link">About</a>
  </nav>
</header>

<!-- Cmd+K Search Palette -->
<div class="search-backdrop" id="search-backdrop" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-palette">
    <div class="search-palette-header">
      <svg class="search-palette-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input class="search-palette-input" id="search-palette-input" type="text" placeholder="Search posts…" autocomplete="off" spellcheck="false">
      <span class="search-palette-hint">esc</span>
    </div>
    <div class="search-palette-results" id="search-palette-results"></div>
    <div class="search-palette-footer">
      <span><kbd>↑↓</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script>
(function() {
  // ── Theme toggle ────────────────────────────────────────────
  var THEME_KEY = 'cs-theme';
  var root = document.documentElement;

  function applyTheme(theme) {
    root.setAttribute('data-theme', theme);
    try { localStorage.setItem(THEME_KEY, theme); } catch(e) {}
  }

  // Default: dark. Override only if user previously chose light.
  var saved = null;
  try { saved = localStorage.getItem(THEME_KEY); } catch(e) {}
  applyTheme(saved === 'light' ? 'light' : 'dark');

  var themeBtn = document.getElementById('theme-toggle');
  if (themeBtn) {
    themeBtn.addEventListener('click', function() {
      var current = root.getAttribute('data-theme');
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });
  }

  // ── Nav toggle ──────────────────────────────────────────────
  var navToggle = document.getElementById('nav-toggle');
  var mobileNav = document.getElementById('mobile-nav');
  if (navToggle && mobileNav) {
    navToggle.addEventListener('click', function() {
      var open = mobileNav.classList.toggle('open');
      navToggle.setAttribute('aria-expanded', String(open));
    });
  }

  // ── Cmd+K Search palette ────────────────────────────────────
  var backdrop = document.getElementById('search-backdrop');
  var paletteInput = document.getElementById('search-palette-input');
  var resultsList = document.getElementById('search-palette-results');
  var searchTrigger = document.getElementById('search-trigger');

  var allPosts = [];
  var activeIdx = -1;
  var loaded = false;

  function openPalette() {
    backdrop.classList.add('open');
    paletteInput.focus();
    paletteInput.select();
    if (!loaded) loadPosts();
  }

  function closePalette() {
    backdrop.classList.remove('open');
    activeIdx = -1;
  }

  function loadPosts() {
    loaded = true;
    fetch('/content.json')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var posts = (data.posts || []).concat(data.pages || []);
        allPosts = posts.map(function(p) {
          return { title: p.title || '', path: p.path || p.permalink || '', date: p.date ? p.date.slice(0,10) : '' };
        });
        renderResults(paletteInput.value);
      })
      .catch(function() {
        resultsList.innerHTML = '<p style="text-align:center;padding:24px;color:var(--color-text-muted);font-size:0.875rem;">Search unavailable</p>';
      });
  }

  function renderResults(query) {
    activeIdx = -1;
    var q = query.trim().toLowerCase();
    var items = q
      ? allPosts.filter(function(p) { return p.title.toLowerCase().indexOf(q) !== -1; })
      : allPosts.slice(0, 12);

    if (!items.length) {
      resultsList.innerHTML = '';
      return;
    }

    resultsList.innerHTML = items.map(function(p, i) {
      var url = p.path.startsWith('/') ? p.path : '/' + p.path;
      return '<a class="search-result-item" href="' + url + '" data-idx="' + i + '">' +
        '<span class="search-result-title">' + esc(p.title) + '</span>' +
        '<span class="search-result-date">' + esc(p.date) + '</span>' +
        '</a>';
    }).join('');
  }

  function esc(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function setActive(idx) {
    var items = resultsList.querySelectorAll('.search-result-item');
    items.forEach(function(el) { el.classList.remove('active'); });
    if (idx >= 0 && idx < items.length) {
      items[idx].classList.add('active');
      items[idx].scrollIntoView({ block: 'nearest' });
      activeIdx = idx;
    }
  }

  if (paletteInput) {
    paletteInput.addEventListener('input', function() { renderResults(this.value); });

    paletteInput.addEventListener('keydown', function(e) {
      var items = resultsList.querySelectorAll('.search-result-item');
      if (e.key === 'ArrowDown') { e.preventDefault(); setActive(Math.min(activeIdx + 1, items.length - 1)); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(Math.max(activeIdx - 1, 0)); }
      else if (e.key === 'Enter') {
        if (activeIdx >= 0 && items[activeIdx]) { items[activeIdx].click(); }
        else if (items[0]) { items[0].click(); }
      }
    });
  }

  if (backdrop) {
    backdrop.addEventListener('click', function(e) {
      if (e.target === backdrop) closePalette();
    });
  }

  if (searchTrigger) {
    searchTrigger.addEventListener('click', openPalette);
  }

  document.addEventListener('keydown', function(e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (backdrop && backdrop.classList.contains('open')) { closePalette(); } else { openPalette(); }
    }
    if (e.key === 'Escape' && backdrop && backdrop.classList.contains('open')) { closePalette(); }
  });
})();
</script>
