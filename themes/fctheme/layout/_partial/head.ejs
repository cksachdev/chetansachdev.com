<head>
  <!-- Google Analytics 4 — replace G-XXXXXXXXXX with your GA4 Measurement ID -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-VDR4WJ56Q9"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-VDR4WJ56Q9');
  </script>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0d1117" media="(prefers-color-scheme: dark)">
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">

  <%
    var pageTitle = (page.title && page.title !== config.title)
      ? page.title + ' — ' + config.title
      : config.title;
    var pageDesc = page.description || config.description;
    var pageUrl = config.url + '/' + (page.path || '');
    var pageImage = page.cover || page.thumbnail || (config.url + '/img/og-default.png');
  %>

  <!-- Primary Meta -->
  <meta name="description" content="<%= pageDesc %>">
  <meta name="author" content="Chetan Sachdev">
  <link rel="canonical" href="<%= pageUrl %>">

  <!-- Open Graph (Facebook, LinkedIn) -->
  <meta property="og:type" content="<%= page.layout === 'post' ? 'article' : 'website' %>">
  <meta property="og:title" content="<%= pageTitle %>">
  <meta property="og:description" content="<%= pageDesc %>">
  <meta property="og:url" content="<%= pageUrl %>">
  <meta property="og:site_name" content="<%= config.title %>">
  <meta property="og:image" content="<%= pageImage %>">
  <meta property="og:locale" content="en_US">
  <% if (page.layout === 'post') { %>
  <meta property="article:published_time" content="<%= page.date.toISOString() %>">
  <meta property="article:author" content="Chetan Sachdev">
  <% if (page.tags && page.tags.length) { page.tags.each(function(tag) { %>
  <meta property="article:tag" content="<%= tag.name %>">
  <% }); } %>
  <% } %>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle %>">
  <meta name="twitter:description" content="<%= pageDesc %>">
  <meta name="twitter:image" content="<%= pageImage %>">
  <meta name="twitter:site" content="@cksachdev">
  <meta name="twitter:creator" content="@cksachdev">

  <!-- RSS / Atom feed autodiscovery -->
  <link rel="alternate" type="application/atom+xml" title="<%= config.title %>" href="/atom.xml">

  <link rel="icon" href="/img/favicon.ico">
  <link rel="apple-touch-icon" href="/img/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/img/icon-192.png">
  <title><%= pageTitle %></title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- JSON-LD Structured Data -->
  <% if (page.layout === 'post') { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "<%- page.title.replace(/"/g, '\\"') %>",
    "datePublished": "<%= page.date.toISOString() %>",
    "dateModified": "<%= (page.updated || page.date).toISOString() %>",
    "author": {
      "@type": "Person",
      "name": "<%= config.author %>",
      "url": "<%= config.url %>/about/"
    },
    "publisher": {
      "@type": "Person",
      "name": "<%= config.author %>",
      "url": "<%= config.url %>"
    },
    "url": "<%= config.url %>/<%= page.path %>",
    "description": "<%- (page.description || page.excerpt || '').replace(/<[^>]+>/g, '').replace(/"/g, '\\"').substring(0, 200) %>",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "<%= config.url %>/<%= page.path %>"
    }
  }
  </script>
  <% } else if (page.path === 'about/index.html') { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "<%= config.author %>",
    "url": "<%= config.url %>",
    "sameAs": [
      "https://www.linkedin.com/in/cksachdev/",
      "https://github.com/cksachdev",
      "https://x.com/cksachdev"
    ],
    "jobTitle": "eLearning Developer",
    "worksFor": {
      "@type": "Organization",
      "name": "Freelance"
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bangalore",
      "addressCountry": "IN"
    }
  }
  </script>
  <% } else if (page.type === 'index' || !page.layout || page.layout === 'index') { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "<%= config.title %>",
    "url": "<%= config.url %>",
    "description": "<%= config.description %>",
    "author": {
      "@type": "Person",
      "name": "<%= config.author %>"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": "<%= config.url %>/?s={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <% } %>

  <!-- Icons — Font Awesome 6 Free -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" crossorigin="anonymous">

  <!-- Theme stylesheet -->
  <%- css('css/styles.css') %>

  <!-- Apply saved theme before paint to prevent flash -->
  <script>
    (function() {
      var t = null;
      try { t = localStorage.getItem('cs-theme'); } catch(e) {}
      document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark');
    })();
  </script>
</head>
